# TELEGRAM
BOT_TOKEN=PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE

# LOCAL FIRST / CONTABO READY
RUN_MODE=polling
PORT=5000

# BOT
DB_PATH=crypto_bot.db
REQUEST_TIMEOUT=20
CACHE_TTL_SECONDS=90
SCAN_INTERVAL_SECONDS=300
ENABLE_AUTOSCAN_THREAD=1

# SAFE MODE / RISK MANAGEMENT
SAFE_MODE=1
MAX_OPEN_TRADES=2
DAILY_MAX_LOSSES=2
MIN_TRADE_SCORE=80
MIN_SNIPER_SCORE=85
MIN_AUTOTRADE_SCORE=90
AUTO_TRADE_RISK_PERCENT=1
ENABLE_BREAK_EVEN=1
ENABLE_TRAILING_STOP=1

# KRAKEN PRO TRADING
# 0 = paper mode sécurisé / 1 = vrais ordres
ENABLE_LIVE_TRADING=0
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
ACCOUNT_EQUITY_USD=1000
MAX_TRADE_QUOTE_USD=100
ALLOW_SPOT_SELL=0

# FUTUR WEBHOOK CONTABO (optionnel)
ADMIN_SECRET=change_me
WEBHOOK_SECRET=change_me_for_future_contabo
EXTERNAL_BASE_URL=

# FREE PUBLIC APIS
BINANCE_BASE_URL=https://api.binance.com
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# V15 Ultra Pro
AUTO_SCAN_FULL_AUTO=1
DYNAMIC_SCORING=1
NEWS_VOLATILITY_FILTER=1
MAX_DAILY_LOSS_PERCENT=3
MIN_VOLUME_RATIO=1.20
MIN_RR=1.50
MAX_BTC_1H_MOVE_PERCENT=3.8
PARTIAL_TP1_PERCENT=50

# V21 Elite Pack
ELITE_MODE=1
MAX_CONSECUTIVE_LOSSES=2

# V22 AI BOT
AI_SCORING=1
AI_MIN_CLOSED_TRADES=8
AI_MAX_SCORE_ADJUST=10
AI_ADAPTIVE_RISK=1
AI_RISK_MIN=0.5
AI_RISK_MAX=1.5
AI_BACKTEST_MIN_WINRATE=55
AI_BACKTEST_MIN_TRADES=5

# V23 Institutional Pack
INSTITUTIONAL_MODE=1
INSTITUTIONAL_MIN_SCORE=88
INSTITUTIONAL_MIN_RR=1.70
INSTITUTIONAL_MIN_VOLUME_RATIO=1.25
PRICE_CONSENSUS_FILTER=1
MAX_EXCHANGE_SPREAD_PERCENT=0.85
ARBITRAGE_ALERT_PERCENT=0.75
SNIPER_MAX_SECONDS=18
SNIPER_WORKERS=24
AUTO_SCAN_ONLY_BEST=1
AUTO_SCAN_COOLDOWN_HOURS=8

# V25 Hedge AI Pro Pack
V25_MODE=1
HEDGE_SHIELD=1
HEDGE_MAX_BTC_MOVE_PERCENT=2.6
V25_MIN_SCORE=90
V25_MIN_RR=1.85
V25_MIN_VOLUME_RATIO=1.30
V25_MIN_AI_WINRATE=54
V25_SMART_LIMIT_OFFSET_ATR=0.06
V25_REDUCE_RISK_AFTER_LOSS=1
V25_DRAWDOWN_PAUSE_PERCENT=4
V25_MAX_CORRELATED_TRADES=1
V25_TRADE_SESSION_FILTER=1
V25_MIN_HISTORY_TRADES_FOR_AI=12
V25_EXECUTION_RETRY=2
